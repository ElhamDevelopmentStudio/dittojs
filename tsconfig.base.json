{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "@dittosh/core": ["./packages/core/src/index.ts"],
      "@dittosh/generator": ["./packages/generator/src/index.ts"],
      "@dittosh/catalog": ["./packages/catalog/src/index.ts"],
      "@dittosh/registry": ["./packages/registry/src/index.ts"],
      "@dittosh/ui": ["./packages/ui/src/index.ts"],
      "@dittosh/testing": ["./packages/testing/src/index.ts"]
    }
  }
}
