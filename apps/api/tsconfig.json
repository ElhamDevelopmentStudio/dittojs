{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "types": ["node"],
    "paths": {
      "@dittosh/core": ["../../packages/core/dist/index.d.ts"],
      "@dittosh/catalog": ["../../packages/catalog/dist/index.d.ts"],
      "@dittosh/generator": ["../../packages/generator/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules", "src/**/*.test.ts"]
}
