{
  "name": "@dittosh/catalog",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ElhamDevelopmentStudio/dittojs.git",
    "directory": "packages/catalog"
  },
  "homepage": "https://github.com/ElhamDevelopmentStudio/dittojs/tree/main/packages/catalog#readme",
  "bugs": "https://github.com/ElhamDevelopmentStudio/dittojs/issues",
  "dependencies": {
    "@dittosh/core": "workspace:*"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -b ../core/tsconfig.json && tsc --noEmit -p tsconfig.typecheck.json",
    "lint": "eslint src --max-warnings=0",
    "test": "tsc -b ../core/tsconfig.json && vitest run --root . --config ../../vitest.config.ts --passWithNoTests",
    "clean": "rm -rf dist coverage"
  }
}
